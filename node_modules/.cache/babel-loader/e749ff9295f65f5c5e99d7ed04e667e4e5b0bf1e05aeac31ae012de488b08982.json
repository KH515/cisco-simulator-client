c4, \"ApplyBtn\");\n$RefreshReg$(_c5, \"InfoBox\");\n$RefreshReg$(_c6, \"IPModal\");\n$RefreshReg$(_c7, \"PortModal\");\n$RefreshReg$(_c8, \"VLANModal\");\n$RefreshReg$(_c9, \"HostnameModal\");\n$RefreshReg$(_c0, \"SaveModal\");\n$RefreshReg$(_c1, \"ShowModal\");\n$RefreshReg$(_c10, \"BannerModal\");\n$RefreshReg$(_c11, \"PasswordModal\");\n$RefreshReg$(_c12, \"StaticRouteModal\");\n$RefreshReg$(_c13, \"Card\");\n$RefreshReg$(_c14, \"DevicePage\");\n$RefreshReg$(_c15, \"GUI\");","map":{"version":3,"names":["React","useState","jsxDEV","_jsxDEV","Fragment","_Fragment","Modal","title","onClose","children","style","position","inset","background","backdropFilter","display","alignItems","justifyContent","zIndex","borderRadius","padding","width","boxShadow","maxHeight","overflowY","marginBottom","fontSize","fontWeight","color","fileName","_jsxFileName","lineNumber","columnNumber","onClick","border","height","cursor","_c","Field","label","value","onChange","placeholder","type","e","target","outline","fontFamily","boxSizing","_c2","Select","options","map","o","_c3","ApplyBtn","gap","marginTop","_c4","InfoBox","text","_c5","ifaces","IPModal","onCommand","_s","iface","setIface","ip","setIp","mask","setMask","apply","setTimeout","i","_c6","PortModal","_s2","action","setAction","_c7","VLANModal","_s3","vlanId","setVlanId","vlanName","setVlanName","mode","setMode","_c8","HostnameModal","_s4","name","setName","_c9","SaveModal","_c0","ShowModal","_s5","cmd","setCmd","cmds","_c1","BannerModal","_s6","msg","setMsg","_c10","PasswordModal","_s7","pass","setPass","setType","_c11","StaticRouteModal","_s8","network","setNetwork","next","setNext","_c12","Card","icon","desc","badge","textAlign","transition","flexDirection","onMouseEnter","currentTarget","transform","borderColor","onMouseLeave","top","left","viewBox","fill","stroke","strokeWidth","strokeLinecap","strokeLinejoin","lineHeight","_c13","DevicePage","category","onBack","devices","switches","model","ports","ios","layer","protocols","routers","firewalls","cables","wireless","cats","catColors","list","flex","points","length","gridTemplateColumns","device","flexShrink","textTransform","letterSpacing","flexWrap","p","j","_c14","GUI","_s9","modal","setModal","devicePage","setDevicePage","configCards","id","x","y","rx","d","x1","y1","x2","y2","ry","deviceCards","count","modals","port","vlan","hostname","save","show","password","banner","route","card","borderTop","paddingTop","_c15","$RefreshReg$"],"sources":["C:/Users/Win11/Desktop/cisco-simulator/client/src/components/GUI.jsx"],"sourcesContent":["import React, { useState } from \"react\";\n\nconst Modal = ({ title, onClose, children }) => (\n  <div style={{ position:\"fixed\", inset:0, background:\"#00000077\", backdropFilter:\"blur(4px)\", display:\"flex\", alignItems:\"center\", justifyContent:\"center\", zIndex:200 }}>\n    <div style={{ background:\"#fff\", borderRadius:16, padding:\"28px 32px\", width:420, boxShadow:\"0 24px 60px #00000025\", maxHeight:\"90vh\", overflowY:\"auto\" }}>\n      <div style={{ display:\"flex\", alignItems:\"center\", justifyContent:\"space-between\", marginBottom:20 }}>\n        <div style={{ fontSize:16, fontWeight:700, color:\"#111827\" }}>{title}</div>\n        <button onClick={onClose} style={{ background:\"#f3f4f6\", border:\"none\", borderRadius:6, width:28, height:28, cursor:\"pointer\", fontSize:16, color:\"#6b7280\" }}>x</button>\n      </div>\n      {children}\n    </div>\n  </div>\n);\n\nconst Field = ({ label, value, onChange, placeholder, type=\"text\" }) => (\n  <div style={{ marginBottom:14 }}>\n    <div style={{ fontSize:11, fontWeight:600, color:\"#374151\", marginBottom:5 }}>{label}</div>\n    <input type={type} value={value} onChange={e=>onChange(e.target.value)} placeholder={placeholder}\n      style={{ width:\"100%\", padding:\"9px 12px\", border:\"1px solid #e5e7eb\", borderRadius:8, fontSize:13, outline:\"none\", fontFamily:\"monospace\", boxSizing:\"border-box\", background:\"#f9fafb\", color:\"#111827\" }} />\n  </div>\n);\n\nconst Select = ({ label, value, onChange, options }) => (\n  <div style={{ marginBottom:14 }}>\n    <div style={{ fontSize:11, fontWeight:600, color:\"#374151\", marginBottom:5 }}>{label}</div>\n    <select value={value} onChange={e=>onChange(e.target.value)}\n      style={{ width:\"100%\", padding:\"9px 12px\", border:\"1px solid #e5e7eb\", borderRadius:8, fontSize:13, outline:\"none\", fontFamily:\"monospace\", boxSizing:\"border-box\", background:\"#f9fafb\", color:\"#111827\" }}>\n      {options.map(o => <option key={o.value} value={o.value}>{o.label}</option>)}\n    </select>\n  </div>\n);\n\nconst ApplyBtn = ({ onClick, label=\"Apply\" }) => (\n  <div style={{ display:\"flex\", justifyContent:\"flex-end\", gap:10, marginTop:20 }}>\n    <button onClick={onClick} style={{ background:\"#1d4ed8\", border:\"none\", color:\"#fff\", padding:\"10px 24px\", borderRadius:8, cursor:\"pointer\", fontSize:13, fontWeight:700 }}>{label}</button>\n  </div>\n);\n\nconst InfoBox = ({ text }) => (\n  <div style={{ background:\"#eff6ff\", border:\"1px solid #bfdbfe\", borderRadius:8, padding:\"10px 14px\", fontSize:11, color:\"#1e40af\", marginBottom:16 }}>{text}</div>\n);\n\nconst ifaces = [\"GigabitEthernet0/0\",\"GigabitEthernet0/1\",\"GigabitEthernet0/2\",\"GigabitEthernet0/3\",\"Vlan1\"];\n\nconst IPModal = ({ onClose, onCommand }) => {\n  const [iface, setIface] = useState(\"GigabitEthernet0/0\");\n  const [ip, setIp] = useState(\"\"); const [mask, setMask] = useState(\"255.255.255.0\");\n  const apply = () => { if(!ip) return; onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`interface ${iface}`); setTimeout(()=>{ onCommand(`ip address ${ip} ${mask}`); setTimeout(()=>{ onCommand(\"no shutdown\"); setTimeout(()=>onCommand(\"end\"),200); },200); },200); },200); onClose(); };\n  return (<Modal title=\"Set IP Address\" onClose={onClose}><InfoBox text=\"Assign an IP address to a network interface.\" /><Select label=\"Interface\" value={iface} onChange={setIface} options={ifaces.map(i=>({value:i,label:i}))} /><Field label=\"IP Address\" value={ip} onChange={setIp} placeholder=\"e.g. 192.168.1.1\" /><Field label=\"Subnet Mask\" value={mask} onChange={setMask} placeholder=\"e.g. 255.255.255.0\" /><ApplyBtn onClick={apply} label=\"Assign IP\" /></Modal>);\n};\n\nconst PortModal = ({ onClose, onCommand }) => {\n  const [iface, setIface] = useState(\"GigabitEthernet0/1\"); const [action, setAction] = useState(\"enable\");\n  const apply = () => { onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`interface ${iface}`); setTimeout(()=>{ onCommand(action===\"enable\"?\"no shutdown\":\"shutdown\"); setTimeout(()=>onCommand(\"end\"),200); },200); },200); onClose(); };\n  return (<Modal title=\"Enable / Disable Port\" onClose={onClose}><InfoBox text=\"Control the administrative state of a port.\" /><Select label=\"Interface\" value={iface} onChange={setIface} options={ifaces.map(i=>({value:i,label:i}))} /><Select label=\"Action\" value={action} onChange={setAction} options={[{value:\"enable\",label:\"Enable Port (no shutdown)\"},{value:\"disable\",label:\"Disable Port (shutdown)\"}]} /><ApplyBtn onClick={apply} label=\"Apply\" /></Modal>);\n};\n\nconst VLANModal = ({ onClose, onCommand }) => {\n  const [vlanId, setVlanId] = useState(\"\"); const [vlanName, setVlanName] = useState(\"\"); const [iface, setIface] = useState(\"GigabitEthernet0/1\"); const [mode, setMode] = useState(\"access\");\n  const apply = () => { if(!vlanId) return; onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`vlan ${vlanId}`); setTimeout(()=>{ if(vlanName) onCommand(`name ${vlanName}`); setTimeout(()=>{ onCommand(\"exit\"); setTimeout(()=>{ onCommand(`interface ${iface}`); setTimeout(()=>{ onCommand(`switchport mode ${mode}`); setTimeout(()=>{ onCommand(`switchport access vlan ${vlanId}`); setTimeout(()=>onCommand(\"end\"),200); },200); },200); },200); },200); },200); },200); onClose(); };\n  return (<Modal title=\"Configure VLAN\" onClose={onClose}><InfoBox text=\"Create a VLAN and assign it to an interface.\" /><Field label=\"VLAN ID\" value={vlanId} onChange={setVlanId} placeholder=\"e.g. 10\" /><Field label=\"VLAN Name (optional)\" value={vlanName} onChange={setVlanName} placeholder=\"e.g. Management\" /><Select label=\"Interface\" value={iface} onChange={setIface} options={ifaces.map(i=>({value:i,label:i}))} /><Select label=\"Port Mode\" value={mode} onChange={setMode} options={[{value:\"access\",label:\"Access\"},{value:\"trunk\",label:\"Trunk\"}]} /><ApplyBtn onClick={apply} label=\"Create VLAN\" /></Modal>);\n};\n\nconst HostnameModal = ({ onClose, onCommand }) => {\n  const [name, setName] = useState(\"\");\n  const apply = () => { if(!name) return; onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`hostname ${name}`); setTimeout(()=>onCommand(\"end\"),200); },200); onClose(); };\n  return (<Modal title=\"Change Hostname\" onClose={onClose}><InfoBox text=\"Set a custom name for the network device.\" /><Field label=\"New Hostname\" value={name} onChange={setName} placeholder=\"e.g. CoreSwitch\" /><ApplyBtn onClick={apply} label=\"Change\" /></Modal>);\n};\n\nconst SaveModal = ({ onClose, onCommand }) => {\n  const apply = () => { onCommand(\"write memory\"); onClose(); };\n  return (<Modal title=\"Save Configuration\" onClose={onClose}><InfoBox text=\"Save the running configuration to NVRAM.\" /><div style={{ fontSize:13, color:\"#374151\", marginBottom:16 }}>This will execute: <span style={{ fontFamily:\"monospace\", background:\"#f3f4f6\", padding:\"2px 8px\", borderRadius:4 }}>write memory</span></div><ApplyBtn onClick={apply} label=\"Save Now\" /></Modal>);\n};\n\nconst ShowModal = ({ onClose, onCommand }) => {\n  const [cmd, setCmd] = useState(\"show ip interface brief\");\n  const cmds = [{value:\"show ip interface brief\",label:\"Interface Status\"},{value:\"show running-config\",label:\"Running Config\"},{value:\"show version\",label:\"IOS Version\"},{value:\"show vlan brief\",label:\"VLAN Table\"},{value:\"show interfaces\",label:\"All Interfaces Detail\"}];\n  const apply = () => { onCommand(cmd); onClose(); };\n  return (<Modal title=\"Show Network Status\" onClose={onClose}><InfoBox text=\"Display current network information.\" /><Select label=\"What to show?\" value={cmd} onChange={setCmd} options={cmds} /><ApplyBtn onClick={apply} label=\"Show\" /></Modal>);\n};\n\nconst BannerModal = ({ onClose, onCommand }) => {\n  const [msg, setMsg] = useState(\"\");\n  const apply = () => { if(!msg) return; onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`banner motd # ${msg} #`); setTimeout(()=>onCommand(\"end\"),200); },200); onClose(); };\n  return (<Modal title=\"Set Login Banner\" onClose={onClose}><InfoBox text=\"Set a message that appears when users log in.\" /><Field label=\"Banner Message\" value={msg} onChange={setMsg} placeholder=\"e.g. Authorized Access Only\" /><ApplyBtn onClick={apply} label=\"Set Banner\" /></Modal>);\n};\n\nconst PasswordModal = ({ onClose, onCommand }) => {\n  const [pass, setPass] = useState(\"\"); const [type, setType] = useState(\"enable\");\n  const apply = () => { if(!pass) return; onCommand(\"configure terminal\"); setTimeout(()=>{ if(type===\"enable\"){ onCommand(`enable secret ${pass}`); setTimeout(()=>onCommand(\"end\"),200); } else { onCommand(\"line console 0\"); setTimeout(()=>{ onCommand(`password ${pass}`); setTimeout(()=>{ onCommand(\"login\"); setTimeout(()=>onCommand(\"end\"),200); },200); },200); } },200); onClose(); };\n  return (<Modal title=\"Set Password\" onClose={onClose}><InfoBox text=\"Configure device access passwords.\" /><Select label=\"Password Type\" value={type} onChange={setType} options={[{value:\"enable\",label:\"Enable Secret (Privileged)\"},{value:\"console\",label:\"Console Password\"}]} /><Field label=\"Password\" value={pass} onChange={setPass} placeholder=\"Enter password\" type=\"password\" /><ApplyBtn onClick={apply} label=\"Set Password\" /></Modal>);\n};\n\nconst StaticRouteModal = ({ onClose, onCommand }) => {\n  const [network, setNetwork] = useState(\"\"); const [mask, setMask] = useState(\"255.255.255.0\"); const [next, setNext] = useState(\"\");\n  const apply = () => { if(!network||!next) return; onCommand(\"configure terminal\"); setTimeout(()=>{ onCommand(`ip route ${network} ${mask} ${next}`); setTimeout(()=>onCommand(\"end\"),200); },200); onClose(); };\n  return (<Modal title=\"Add Static Route\" onClose={onClose}><InfoBox text=\"Add a static route to the routing table.\" /><Field label=\"Destination Network\" value={network} onChange={setNetwork} placeholder=\"e.g. 192.168.2.0\" /><Field label=\"Subnet Mask\" value={mask} onChange={setMask} placeholder=\"e.g. 255.255.255.0\" /><Field label=\"Next Hop (Gateway)\" value={next} onChange={setNext} placeholder=\"e.g. 192.168.1.254\" /><ApplyBtn onClick={apply} label=\"Add Route\" /></Modal>);\n};\n\nconst Card = ({ icon, title, desc, color, onClick, badge }) => (\n  <button onClick={onClick} style={{ background:\"#fff\", border:\"1px solid #e5e7eb\", borderRadius:14, padding:\"20px 18px\", cursor:\"pointer\", textAlign:\"left\", transition:\"all 0.15s\", display:\"flex\", flexDirection:\"column\", gap:10, boxShadow:\"0 1px 3px #0000000a\", position:\"relative\" }}\n    onMouseEnter={e=>{ e.currentTarget.style.transform=\"translateY(-2px)\"; e.currentTarget.style.boxShadow=`0 8px 24px ${color}22`; e.currentTarget.style.borderColor=color; }}\n    onMouseLeave={e=>{ e.currentTarget.style.transform=\"translateY(0)\"; e.currentTarget.style.boxShadow=\"0 1px 3px #0000000a\"; e.currentTarget.style.borderColor=\"#e5e7eb\"; }}>\n    {badge && <div style={{ position:\"absolute\", top:10, left:10, background:color, color:\"#fff\", fontSize:9, fontWeight:700, padding:\"2px 7px\", borderRadius:10 }}>{badge}</div>}\n    <div style={{ width:44, height:44, borderRadius:12, background:`${color}15`, display:\"flex\", alignItems:\"center\", justifyContent:\"center\" }}>\n      <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke={color} strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">{icon}</svg>\n    </div>\n    <div>\n      <div style={{ fontSize:13, fontWeight:700, color:\"#111827\", marginBottom:3 }}>{title}</div>\n      <div style={{ fontSize:11, color:\"#9ca3af\", lineHeight:1.5 }}>{desc}</div>\n    </div>\n  </button>\n);\n\n// ??? DEVICE PAGE ???\nconst DevicePage = ({ category, onBack }) => {\n  const devices = {\n    switches: [\n      { model:\"Cisco 2960-24TT\", desc:\"24 ���� Fast Ethernet + 2 Uplink � ����� ������� ������� ���������\", ports:\"24 FE + 2 GE\", ios:\"15.0(2)SE4\", layer:\"Layer 2\", protocols:[\"VLAN\",\"STP\",\"VTP\",\"CDP\"], color:\"#1d4ed8\" },\n      { model:\"Cisco 2960-48TT\", desc:\"48 ���� Fast Ethernet � ����� ������� �������\", ports:\"48 FE + 2 GE\", ios:\"15.0(2)SE4\", layer:\"Layer 2\", protocols:[\"VLAN\",\"STP\",\"VTP\",\"EtherChannel\"], color:\"#1d4ed8\" },\n      { model:\"Cisco 3560-24PS\", desc:\"24 ���� PoE � ���� Layer 3 Routing\", ports:\"24 FE PoE + 2 GE\", ios:\"12.2(55)SE\", layer:\"Layer 3\", protocols:[\"VLAN\",\"OSPF\",\"EIGRP\",\"STP\",\"RIP\"], color:\"#0e7490\" },\n      { model:\"Cisco 3750-48TS\", desc:\"48 ���� �� StackWise � ���� ����� ��� �������\", ports:\"48 GE + 4 SFP\", ios:\"12.2(55)SE\", layer:\"Layer 3\", protocols:[\"VLAN\",\"OSPF\",\"EIGRP\",\"StackWise\"], color:\"#0e7490\" },\n      { model:\"Cisco 9200-24P\", desc:\"���� ��� � ���� SD-Access � DNA Center\", ports:\"24 GE PoE + 4 SFP\", ios:\"17.x\", layer:\"Layer 3\", protocols:[\"VLAN\",\"OSPF\",\"BGP\",\"LISP\",\"VXLAN\"], color:\"#7c3aed\" },\n    ],\n    routers: [\n      { model:\"Cisco 1941\", desc:\"����� ������� ������� � ���� ���� ���������� CCNA\", ports:\"2 GE + 2 WAN\", ios:\"15.1(4)M4\", layer:\"Layer 3\", protocols:[\"OSPF\",\"EIGRP\",\"RIP\",\"BGP\",\"NAT\",\"ACL\"], color:\"#15803d\" },\n      { model:\"Cisco 2901\", desc:\"����� ����� � ����� ������ �������� ��������\", ports:\"2 GE + Modules\", ios:\"15.1(4)M4\", layer:\"Layer 3\", protocols:[\"OSPF\",\"EIGRP\",\"BGP\",\"MPLS\",\"NAT\",\"VPN\"], color:\"#15803d\" },\n      { model:\"Cisco 2911\", desc:\"������� ������ �� ������� CCNA/CCNP\", ports:\"3 GE + 4 Slots\", ios:\"15.1(4)M4\", layer:\"Layer 3\", protocols:[\"OSPF\",\"EIGRP\",\"BGP\",\"RIP\",\"NAT\",\"DHCP\",\"ACL\"], color:\"#15803d\" },\n      { model:\"Cisco 4321\", desc:\"����� ������ ������� � ���� Virtualization\", ports:\"2 GE + 2 SFP\", ios:\"16.x\", layer:\"Layer 3\", protocols:[\"OSPF\",\"BGP\",\"MPLS\",\"VRF\",\"NAT\",\"QoS\"], color:\"#065f46\" },\n      { model:\"Cisco ISR 1100\", desc:\"���� ��� ISR � ���� �� WiFi �LTE\", ports:\"4 GE + LTE\", ios:\"17.x\", layer:\"Layer 3\", protocols:[\"OSPF\",\"BGP\",\"SD-WAN\",\"DMVPN\",\"NAT\"], color:\"#065f46\" },\n    ],\n    firewalls: [\n      { model:\"Cisco ASA 5505\", desc:\"���� ������� ������� � ����� ������� �������\", ports:\"8 FE\", ios:\"ASA 9.2\", layer:\"Layer 3-7\", protocols:[\"NAT\",\"ACL\",\"VPN\",\"IPS\",\"DMZ\"], color:\"#b91c1c\" },\n      { model:\"Cisco ASA 5506-X\", desc:\"���� FirePOWER IPS � ����� ������\", ports:\"8 GE + 1 Mgmt\", ios:\"ASA 9.8\", layer:\"Layer 3-7\", protocols:[\"NAT\",\"ACL\",\"IPS\",\"URL Filtering\",\"VPN\"], color:\"#b91c1c\" },\n      { model:\"Cisco ASA 5516-X\", desc:\"������� �������� � ���� ����\", ports:\"8 GE + 2 SFP\", ios:\"ASA 9.8\", layer:\"Layer 3-7\", protocols:[\"NAT\",\"ACL\",\"IPS\",\"SSL VPN\",\"BGP\"], color:\"#92400e\" },\n      { model:\"Cisco FTD 1010\", desc:\"Firepower Threat Defense � ����� ������\", ports:\"8 GE\", ios:\"FTD 7.x\", layer:\"Layer 3-7\", protocols:[\"IPS\",\"Malware\",\"URL\",\"VPN\",\"RA-VPN\"], color:\"#92400e\" },\n    ],\n    protocols: [\n      { model:\"VLAN\", desc:\"Virtual Local Area Network � ����� ������ ������� ���� ����� �������\", ports:\"802.1Q Tagging\", ios:\"All IOS\", layer:\"Layer 2\", protocols:[\"Access Port\",\"Trunk Port\",\"VTP\",\"Native VLAN\"], color:\"#1d4ed8\" },\n      { model:\"STP / RSTP\", desc:\"Spanning Tree Protocol � ��� ������� �� ����� ��� Layer 2\", ports:\"Bridge Protocol\", ios:\"All IOS\", layer:\"Layer 2\", protocols:[\"Root Bridge\",\"BPDUs\",\"Port States\",\"PVST+\"], color:\"#0e7490\" },\n      { model:\"OSPF\", desc:\"Open Shortest Path First � �������� ����� ����� ���� ������\", ports:\"Protocol 89\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"Areas\",\"LSA\",\"DR/BDR\",\"SPF Algorithm\"], color:\"#15803d\" },\n      { model:\"EIGRP\", desc:\"Enhanced IGRP � �������� Cisco ����ա ���� ����\", ports:\"Protocol 88\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"DUAL Algorithm\",\"Successor\",\"Feasible Successor\",\"K-Values\"], color:\"#15803d\" },\n      { model:\"BGP\", desc:\"Border Gateway Protocol � �������� �������� ��� ��������\", ports:\"TCP 179\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"eBGP\",\"iBGP\",\"AS Number\",\"Route Policies\"], color:\"#065f46\" },\n      { model:\"NAT / PAT\", desc:\"Network Address Translation � ����� �������� ������ ��������\", ports:\"IP Translation\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"Static NAT\",\"Dynamic NAT\",\"PAT\",\"Inside/Outside\"], color:\"#7c3aed\" },\n      { model:\"DHCP\", desc:\"Dynamic Host Configuration Protocol � ����� IP ��������\", ports:\"UDP 67/68\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"IP Pool\",\"Lease Time\",\"Gateway\",\"DNS Server\"], color:\"#92400e\" },\n      { model:\"ACL\", desc:\"Access Control List � ������ �� ���� ������ ������� �� �����\", ports:\"Packet Filtering\", ios:\"All IOS\", layer:\"Layer 3-4\", protocols:[\"Standard ACL\",\"Extended ACL\",\"Named ACL\",\"Wildcard Mask\"], color:\"#b91c1c\" },\n      { model:\"RIP v2\", desc:\"Routing Information Protocol � �������� ����� ���� ������� �������\", ports:\"UDP 520\", ios:\"All IOS\", layer:\"Layer 3\", protocols:[\"Distance Vector\",\"Max 15 Hops\",\"Auto-Summary\",\"Triggered Updates\"], color:\"#b45309\" },\n      { model:\"VTP\", desc:\"VLAN Trunking Protocol � ������ VLANs ��� ��������� ��������\", ports:\"Trunk Links\", ios:\"All IOS\", layer:\"Layer 2\", protocols:[\"Server Mode\",\"Client Mode\",\"Transparent Mode\",\"Pruning\"], color:\"#4f46e5\" },\n    ],\n    cables: [\n      { model:\"Straight-Through\", desc:\"���� ����� ������ � PC ��� Switch �� Router ��� Switch\", ports:\"RJ-45\", ios:\"Cat5e/Cat6\", layer:\"Layer 1\", protocols:[\"568B � 568B\",\"PC to Switch\",\"Router to Switch\"], color:\"#15803d\" },\n      { model:\"Crossover\", desc:\"���� ����� ������� � Switch ��� Switch �� PC ��� PC\", ports:\"RJ-45\", ios:\"Cat5e/Cat6\", layer:\"Layer 1\", protocols:[\"568A � 568B\",\"Switch to Switch\",\"Hub to Hub\"], color:\"#b91c1c\" },\n      { model:\"Console Cable\", desc:\"���� ������� � ���� ��������� ����� Console ������\", ports:\"RJ-45 to DB9\", ios:\"Rollover\", layer:\"Layer 1\", protocols:[\"9600 Baud\",\"8 Data Bits\",\"No Parity\",\"1 Stop Bit\"], color:\"#92400e\" },\n      { model:\"Serial / WAN\", desc:\"���� WAN � ���� ��������� ��� ������ �������\", ports:\"DB-60 / Smart Serial\", ios:\"DCE/DTE\", layer:\"Layer 1\", protocols:[\"DCE � Clock Rate\",\"DTE � Passive\",\"HDLC\",\"PPP\"], color:\"#1d4ed8\" },\n      { model:\"Fiber Optic\", desc:\"���� ������� ������� � ������ ����� ������ �����\", ports:\"SFP / LC / SC\", ios:\"Single/Multi Mode\", layer:\"Layer 1\", protocols:[\"Single Mode � 10km+\",\"Multi Mode � 2km\",\"1Gbps � 100Gbps\"], color:\"#7c3aed\" },\n      { model:\"SFP / GBIC\", desc:\"����� ������� ������� ������� � ����� ����� �� ����\", ports:\"SFP Port\", ios:\"Transceiver\", layer:\"Layer 1\", protocols:[\"1G SFP\",\"10G SFP+\",\"25G SFP28\",\"Hot-Swappable\"], color:\"#0e7490\" },\n    ],\n    wireless: [\n      { model:\"Cisco Aironet 1832\", desc:\"Access Point ������ � ���� 802.11ac Wave 1\", ports:\"2.4GHz + 5GHz\", ios:\"AP IOS\", layer:\"Layer 2\", protocols:[\"802.11ac\",\"WPA2\",\"CAPWAP\",\"EAP\"], color:\"#15803d\" },\n      { model:\"Cisco Aironet 2802\", desc:\"Access Point ����� � 802.11ac Wave 2 �� MU-MIMO\", ports:\"2.4GHz + 5GHz\", ios:\"AP IOS\", layer:\"Layer 2\", protocols:[\"802.11ac W2\",\"MU-MIMO\",\"CAPWAP\",\"802.1X\"], color:\"#0e7490\" },\n      { model:\"Cisco WLC 3504\", desc:\"Wireless LAN Controller � ����� �� ��� 150 Access Point\", ports:\"4 GE + 2 SFP\", ios:\"AireOS 8.x\", layer:\"Layer 2-3\", protocols:[\"CAPWAP\",\"LWAPP\",\"802.11r\",\"FlexConnect\"], color:\"#7c3aed\" },\n    ],\n  };\n\n  const cats = { switches:\"Cisco Switches\", routers:\"Cisco Routers\", firewalls:\"Cisco Firewalls\", protocols:\"Network Protocols\", cables:\"Network Cables\", wireless:\"Wireless Devices\" };\n  const catColors = { switches:\"#1d4ed8\", routers:\"#15803d\", firewalls:\"#b91c1c\", protocols:\"#7c3aed\", cables:\"#92400e\", wireless:\"#0e7490\" };\n  const list = devices[category] || [];\n  const color = catColors[category] || \"#1d4ed8\";\n\n  return (\n    <div style={{ flex:1, background:\"#f8fafc\", overflowY:\"auto\", padding:\"24px\" }}>\n      <div style={{ display:\"flex\", alignItems:\"center\", gap:14, marginBottom:24 }}>\n        <button onClick={onBack} style={{ background:\"#fff\", border:\"1px solid #e5e7eb\", borderRadius:8, padding:\"8px 14px\", cursor:\"pointer\", fontSize:12, fontWeight:600, color:\"#374151\", display:\"flex\", alignItems:\"center\", gap:6 }}>\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><polyline points=\"15 18 9 12 15 6\"/></svg>\n          Back\n        </button>\n        <div>\n          <div style={{ fontSize:20, fontWeight:800, color:\"#111827\" }}>{cats[category]}</div>\n          <div style={{ fontSize:12, color:\"#9ca3af\", marginTop:2 }}>{list.length} devices / protocols</div>\n        </div>\n      </div>\n\n      <div style={{ display:\"grid\", gridTemplateColumns:\"repeat(auto-fill, minmax(280px, 1fr))\", gap:16 }}>\n        {list.map((device, i) => (\n          <div key={i} style={{ background:\"#fff\", border:`1px solid #e5e7eb`, borderRadius:14, padding:\"20px\", boxShadow:\"0 1px 3px #0000000a\", transition:\"all 0.15s\" }}\n            onMouseEnter={e=>{ e.currentTarget.style.borderColor=color; e.currentTarget.style.boxShadow=`0 8px 24px ${color}15`; e.currentTarget.style.transform=\"translateY(-2px)\"; }}\n            onMouseLeave={e=>{ e.currentTarget.style.borderColor=\"#e5e7eb\"; e.currentTarget.style.boxShadow=\"0 1px 3px #0000000a\"; e.currentTarget.style.transform=\"translateY(0)\"; }}>\n            <div style={{ display:\"flex\", alignItems:\"flex-start\", justifyContent:\"space-between\", marginBottom:12 }}>\n              <div style={{ fontSize:14, fontWeight:800, color:\"#111827\" }}>{device.model}</div>\n              <div style={{ fontSize:9, fontWeight:700, color:\"#fff\", background:device.color, padding:\"3px 8px\", borderRadius:6, flexShrink:0 }}>{device.layer}</div>\n            </div>\n            <div style={{ fontSize:12, color:\"#6b7280\", lineHeight:1.6, marginBottom:14 }}>{device.desc}</div>\n            <div style={{ display:\"grid\", gridTemplateColumns:\"1fr 1fr\", gap:8, marginBottom:14 }}>\n              <div style={{ background:\"#f8fafc\", borderRadius:8, padding:\"8px 10px\" }}>\n                <div style={{ fontSize:9, color:\"#9ca3af\", marginBottom:2 }}>PORTS</div>\n                <div style={{ fontSize:11, fontWeight:600, color:\"#374151\" }}>{device.ports}</div>\n              </div>\n              <div style={{ background:\"#f8fafc\", borderRadius:8, padding:\"8px 10px\" }}>\n                <div style={{ fontSize:9, color:\"#9ca3af\", marginBottom:2 }}>IOS / STANDARD</div>\n                <div style={{ fontSize:11, fontWeight:600, color:\"#374151\" }}>{device.ios}</div>\n              </div>\n            </div>\n            <div style={{ fontSize:9, color:\"#9ca3af\", marginBottom:6, textTransform:\"uppercase\", letterSpacing:1 }}>Supported Protocols</div>\n            <div style={{ display:\"flex\", flexWrap:\"wrap\", gap:4 }}>\n              {device.protocols.map((p,j) => (\n                <span key={j} style={{ fontSize:10, background:`${device.color}12`, color:device.color, border:`1px solid ${device.color}30`, padding:\"2px 8px\", borderRadius:4, fontWeight:600 }}>{p}</span>\n              ))}\n            </div>\n          </div>\n        ))}\n      </div>\n    </div>\n  );\n};\n\n// ??? MAIN GUI ???\nexport default function GUI({ onCommand }) {\n  const [modal, setModal] = useState(null);\n  const [devicePage, setDevicePage] = useState(null);\n\n  if (devicePage) return <DevicePage category={devicePage} onBack={()=>setDevicePage(null)} />;\n\n  const configCards = [\n    { id:\"ip\", color:\"#1d4ed8\", title:\"Set IP Address\", desc:\"Assign IP to any interface\", icon:<><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\"/><path d=\"M8 21h8M12 17v4\"/></> },\n    { id:\"port\", color:\"#15803d\", title:\"Enable / Disable Port\", desc:\"Control port state on/off\", icon:<><path d=\"M18.36 6.64a9 9 0 1 1-12.73 0\"/><line x1=\"12\" y1=\"2\" x2=\"12\" y2=\"12\"/></> },\n    { id:\"vlan\", color:\"#0e7490\", title:\"Configure VLAN\", desc:\"Create VLANs and assign ports\", icon:<><polygon points=\"12 2 2 7 12 12 22 7 12 2\"/><polyline points=\"2 17 12 22 22 17\"/><polyline points=\"2 12 12 17 22 12\"/></> },\n    { id:\"hostname\", color:\"#7c3aed\", title:\"Change Hostname\", desc:\"Set device name\", icon:<><path d=\"M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7\"/><path d=\"M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z\"/></> },\n    { id:\"save\", color:\"#92400e\", title:\"Save Configuration\", desc:\"Save settings to NVRAM\", icon:<><path d=\"M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z\"/><polyline points=\"17 21 17 13 7 13 7 21\"/><polyline points=\"7 3